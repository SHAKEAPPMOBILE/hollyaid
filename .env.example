# Supabase (required)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Where the login link in the email should send users (optional).
# If unset, the app uses the current site (e.g. localhost in dev).
# On Netlify/production, set this so magic links open your app, not Lovable:
#   VITE_AUTH_REDIRECT_URL=https://hollyaidapp.netlify.app
# or
#   VITE_AUTH_REDIRECT_URL=https://hollyaid.com
# (no trailing slash)
